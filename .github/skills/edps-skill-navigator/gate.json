{
  "$schema": "https://edps.dev/schemas/gate/v1.0.0",
  "skill_id": "S30",
  "skill_name": "edps-skill-navigator",
  "version": "1.3.0",
  "gate_type": "completion",
  "severity": "hard",
  "description": "Validates skill navigation and orchestration properly configured",
  "checks": [
    {
      "id": "navigation_complete",
      "type": "content_pattern",
      "severity": "hard",
      "description": "Must have provided skill navigation response",
      "file": "artifacts/Analysis/skill-navigation-response.md",
      "must_contain": ["Skill ID:", "Workflow Archetype:"],
      "remediation": "Run edps-skill-navigator to identify and route to appropriate skill"
    },
    {
      "id": "skill_found",
      "type": "content_pattern",
      "severity": "hard",
      "description": "Should successfully identify useful skill",
      "file": "artifacts/Analysis/skill-navigation-response.md",
      "must_not_contain": ["No suitable skill found", "Unable to route"],
      "remediation": "Refine user request or expand skill coverage"
    },
    {
      "id": "confidence_threshold",
      "type": "content_pattern",
      "severity": "soft",
      "description": "Should have high confidence in routing decision",
      "file": "artifacts/Analysis/skill-navigation-response.md",
      "must_contain_pattern": "Confidence: [89][0-9]%|100%",
      "remediation": "Consider manual skill selection for low confidence routing"
    }
  ],
  "quality_score_weight": 0.08,
  "bypass_allowed": false,
  "workflow_archetypes": {
    "standard": "hard",
    "rapid": "soft",
    "compliance": "hard"
  }
}