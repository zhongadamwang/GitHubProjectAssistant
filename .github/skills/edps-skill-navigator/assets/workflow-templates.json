# EDPS Workflow Templates

## Template: Complete Project Initiation

```json
{
  "name": "complete_project_initiation",
  "description": "Full project setup from requirements to initial analysis",
  "trigger_patterns": [
    "start new project",
    "initialize project", 
    "setup project with requirements",
    "begin EDPS project"
  ],
  "prerequisites": {
    "required": ["requirements_document"],
    "optional": ["project_name", "team_information"]
  },
  "workflow": {
    "steps": [
      {
        "step": 1,
        "skill": "project-document-management",
        "purpose": "Create standardized project structure",
        "inputs": ["project_name"],
        "outputs": ["project_structure"],
        "duration": "2-3 minutes",
        "critical": true
      },
      {
        "step": 2,
        "skill": "requirements-ingest", 
        "purpose": "Process and normalize requirements",
        "inputs": ["requirements_document", "project_structure"],
        "outputs": ["requirements.md", "requirements.json"],
        "duration": "3-5 minutes",
        "critical": true
      },
      {
        "step": 3,
        "skill": "goals-extract",
        "purpose": "Identify business objectives and success criteria",
        "inputs": ["requirements.md"],
        "outputs": ["goals.md", "goals.json"],
        "duration": "2-4 minutes", 
        "critical": true
      },
      {
        "step": 4,
        "skill": "process-w5h",
        "purpose": "Comprehensive contextual analysis",
        "inputs": ["requirements.md", "goals.md"],
        "outputs": ["w5h-analysis.md", "w5h-analysis.json"],
        "duration": "4-6 minutes",
        "critical": false
      },
      {
        "step": 5,
        "skill": "domain-extractconcepts",
        "purpose": "Identify domain entities and relationships", 
        "inputs": ["requirements.md", "w5h-analysis.md"],
        "outputs": ["domain-concepts.md", "domain-concepts.json"],
        "duration": "3-5 minutes",
        "critical": false
      },
      {
        "step": 6,
        "skill": "domain-alignentities",
        "purpose": "Align concepts with organizational standards",
        "inputs": ["domain-concepts.md"],
        "outputs": ["domain-alignment.md", "domain-alignment.json"],
        "duration": "2-4 minutes",
        "critical": false,
        "conditional": "if organizational standards available"
      }
    ],
    "parallel_opportunities": [
      {
        "steps": [3, 4],
        "note": "Goals extraction and W5H analysis can run simultaneously"
      }
    ],
    "checkpoints": [
      {
        "after_step": 2,
        "check": "Requirements successfully processed",
        "failure_action": "Manual requirements review"
      },
      {
        "after_step": 5, 
        "check": "Domain concepts identified (minimum 5)",
        "failure_action": "Guided concept identification"
      }
    ]
  },
  "success_criteria": [
    "Project structure created",
    "Requirements processed and normalized", 
    "Business goals identified",
    "Domain model foundation established"
  ],
  "estimated_total_duration": "15-25 minutes",
  "user_interaction_points": [
    "Project name confirmation",
    "Requirements document upload",
    "Optional: Review extracted goals",
    "Optional: Review domain concepts"
  ]
}
```

