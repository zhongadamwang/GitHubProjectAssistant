# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_BASE_PATH=

# ─────────────────────────────────────────────
# Database (MySQL via PDO)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=scrum_dashboard
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# ─────────────────────────────────────────────
# GitHub API (GraphQL v4)
# ─────────────────────────────────────────────
# Personal Access Token with read:project and read:org scopes
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-github-org-or-username
GITHUB_GRAPHQL_URL=https://api.github.com/graphql

# ─────────────────────────────────────────────
# PHP Sessions
# ─────────────────────────────────────────────
SESSION_NAME=scrum_session
# Secure cookie (set to true in production over HTTPS)
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict
# Session lifetime in seconds (default: 8 hours)
SESSION_LIFETIME=28800

# ─────────────────────────────────────────────
# Sync
# ─────────────────────────────────────────────
# Interval between cron runs (minutes) — informational, not enforced here
SYNC_INTERVAL_MINUTES=15
# Maximum JSON snapshot files to retain (older ones will be pruned)
SNAPSHOT_RETENTION_COUNT=200
