# =============================================================================
# .env.example — ScrumMasterTool environment configuration template
#
# Copy this file to .env and fill in real values before running the app.
#   cp .env.example .env
#
# DO NOT COMMIT .env — it contains secrets.
# This file (.env.example) is safe to commit and contains only placeholders.
# =============================================================================

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development
# Set to "production" on cPanel — disables debug output and enables secure cookies
# APP_ENV=production

APP_DEBUG=true
# Set to false in production
# APP_DEBUG=false

# Subdirectory path if app is not at the domain root (e.g. /dashboard).
# Leave empty if installed at the document root.
APP_BASE_PATH=

# Full public URL of the application (used for absolute link generation)
APP_URL=http://localhost:5173

# ─────────────────────────────────────────────
# Database (MySQL via PDO)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=scrum_dashboard
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# ─────────────────────────────────────────────
# GitHub API (GraphQL v4)
# ─────────────────────────────────────────────
# Personal Access Token — required scopes: read:project
# (add read:org if your project lives under a GitHub organization)
#
# How to generate:
#   1. Go to https://github.com/settings/tokens → "Generate new token (classic)"
#   2. Select scopes: read:project  (and optionally read:org)
#   3. Copy the token — it will only be shown once
#   4. Paste it below — NEVER commit this value
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username or organization name that owns the project
GITHUB_ORG=your-github-org-or-username

# The sequential number shown in the GitHub Projects URL:
#   github.com/orgs/{org}/projects/{number}  OR
#   github.com/users/{user}/projects/{number}
GITHUB_PROJECT_NUMBER=1

# GitHub GraphQL v4 endpoint — do not change unless using GitHub Enterprise
GITHUB_GRAPHQL_URL=https://api.github.com/graphql

# ─────────────────────────────────────────────
# PHP Sessions
# ─────────────────────────────────────────────
SESSION_NAME=scrum_session

# Set to true in production (requires HTTPS)
SESSION_SECURE=false
# SESSION_SECURE=true

SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict

# Session lifetime in seconds (default: 8 hours = 28800)
SESSION_LIFETIME=28800

# ─────────────────────────────────────────────
# Sync
# ─────────────────────────────────────────────
# Cron interval in minutes — informational only, not enforced by the app code.
# The actual schedule is set in cPanel Cron Jobs (default: */15 * * * *)
SYNC_INTERVAL_MINUTES=15

# Maximum number of JSON snapshot files to retain in data/snapshots/.
# Older files beyond this count are pruned automatically after each sync.
SNAPSHOT_RETENTION_COUNT=200

# ─────────────────────────────────────────────
# Seed / Admin user
# (only read by database/seed.php — not used at runtime)
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin
