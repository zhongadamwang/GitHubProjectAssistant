# ScrumMasterTool — Apache front controller rewrite
# Routes all non-static requests to public/index.php (Slim 4 entry point).

Options -Indexes
DirectoryIndex index.php

# -------------------------------------------------------------------------
# MIME types for static assets (Vue SPA build)
# -------------------------------------------------------------------------
<IfModule mod_mime.c>
    # JavaScript
    AddType application/javascript .js .mjs
    
    # CSS
    AddType text/css .css
    
    # JSON
    AddType application/json .json
    
    # Images
    AddType image/svg+xml .svg
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
    AddType image/gif .gif
    AddType image/webp .webp
    AddType image/x-icon .ico
    
    # Fonts
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType font/ttf .ttf
    AddType font/otf .otf
    AddType application/vnd.ms-fontobject .eot
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If APP_BASE_PATH is set, the RewriteBase must match it.
    # For a root install leave as "/". For a subdirectory (e.g. /dashboard)
    # change to: RewriteBase /dashboard/
    RewriteBase /

    # Allow existing files and directories to be served directly
    # (static assets in public/dist/, favicons, etc.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else to Slim's front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# -------------------------------------------------------------------------
# Security hardening
# -------------------------------------------------------------------------

# Prevent access to hidden files (.env, .git, etc.)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Suppress server version information
ServerSignature Off
