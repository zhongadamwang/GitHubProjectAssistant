# ─────────────────────────────────────────────
# Test environment — copy to .env.test and fill in real values.
# This file is committed; .env.test is NOT committed (see .gitignore).
#
# Use a SEPARATE database from development so tests can truncate freely.
# ─────────────────────────────────────────────

APP_ENV=testing
APP_DEBUG=true
APP_BASE_PATH=

# ─────────────────────────────────────────────
# Test database (MySQL) — separate DB from dev
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=scrum_dashboard_test
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# ─────────────────────────────────────────────
# Test admin seed credentials
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@test.local
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Test Admin

# ─────────────────────────────────────────────
# Sessions (no real cookies in CLI)
# ─────────────────────────────────────────────
SESSION_NAME=scrum_test_session
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict
SESSION_LIFETIME=28800

# ─────────────────────────────────────────────
# GitHub — not used in Phase 1 tests
# ─────────────────────────────────────────────
GITHUB_PAT=
GITHUB_ORG=
GITHUB_GRAPHQL_URL=https://api.github.com/graphql

SYNC_INTERVAL_MINUTES=15
SNAPSHOT_RETENTION_COUNT=200
